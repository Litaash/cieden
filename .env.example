# Required: Google Gemini API key (get one free at https://aistudio.google.com/apikey)
GOOGLE_GENERATIVE_AI_API_KEY=your_google_ai_studio_key_here

# Required: Firecrawl API key (free tier available at https://firecrawl.dev)
FIRECRAWL_API_KEY=your_firecrawl_key_here

# Optional: Vercel Blob token. When set, generated reports are persisted and
# get a shareable /report/[id] URL. When missing, reports are returned only
# in-line via the SSE stream (no persistence).
# Create one at https://vercel.com/dashboard/stores (Blob)
BLOB_READ_WRITE_TOKEN=your_vercel_blob_rw_token_here

# Optional: override model ids (defaults shown).
# By default we use Flash for both tiers — Google removed the free-tier quota
# for gemini-2.5-pro. If you have billing enabled, swap GEMINI_PRO_MODEL to
# gemini-2.5-pro for stronger vision reasoning.
# GEMINI_FLASH_MODEL=gemini-2.5-flash
# GEMINI_PRO_MODEL=gemini-2.5-flash
